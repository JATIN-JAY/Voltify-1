# ==========================================
# BACKEND ENVIRONMENT VARIABLES (.env)
# ==========================================

# Server Configuration
PORT=5004
NODE_ENV=production

# ==========================================
# DATABASE
# ==========================================
# Local: mongodb://localhost:27017/voltify
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/voltify
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/voltify

# ==========================================
# AUTHENTICATION
# ==========================================
JWT_SECRET=generate_random_string_with_at_least_32_chars
JWT_EXPIRATION=7d

# ==========================================
# GOOGLE OAUTH
# ==========================================
# Get from: https://console.cloud.google.com/
# Create OAuth 2.0 credentials (Web application type)
# Authorized redirect URIs:
#   - http://localhost:3000 (local development)
#   - https://voltify-1.vercel.app (Vercel frontend)
#   - https://voltify-1-1.onrender.com (backend for verification)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ==========================================
# PAYMENTS - RAZORPAY
# ==========================================
# Get from: https://dashboard.razorpay.com/app/dashboard
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ==========================================
# IMAGE UPLOAD - CLOUDINARY
# ==========================================
# Get from: https://cloudinary.com/console/
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# EMAIL - NODEMAILER (Optional)
# ==========================================
# For transactional emails
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# ==========================================
# FRONTEND URL (for CORS & Redirects)
# ==========================================
# Development: http://localhost:3000
# Production: https://voltify-1.vercel.app
FRONTEND_URL=https://voltify-1.vercel.app

# ==========================================
# DEPLOYMENT NOTES
# ==========================================
# For Production (Render.com):
# 1. Copy all these variables to Render Environment Variables
# 2. Update URLs to production domains
# 3. Generate strong JWT_SECRET
# 4. Use MongoDB Atlas connection string
# 5. Get API keys from respective services
