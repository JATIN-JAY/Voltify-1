# ==========================================
# FRONTEND ENVIRONMENT VARIABLES (.env.local for development)
# ==========================================

# API Base URL
# Development: http://localhost:5004 (Vite proxies /api to this URL, see vite.config.js)
# Production: Set in Vercel Project Settings → Environment Variables
# DO NOT append /api - api.js automatically adds it (see src/api.js)
VITE_API_URL=http://localhost:5004

# Cloudinary Configuration
# Get credentials from: https://cloudinary.com/console/
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Google OAuth
# Get from: https://console.cloud.google.com/
# Create OAuth 2.0 credentials (Web application)
# Redirect URIs: http://localhost:3000, https://voltify-1.vercel.app
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Cloudinary Configuration
# Get credentials from: https://cloudinary.com/console/
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Google OAuth
# Get from: https://console.cloud.google.com/
# Create OAuth 2.0 credentials (Web application)
# Redirect URIs: http://localhost:3000, https://voltify-1.vercel.app
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
